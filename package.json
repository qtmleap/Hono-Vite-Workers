  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b --noEmit && vite build --mode ${CLOUDFLARE_ENV:-staging}",
    "predeploy": "tsc -b --noEmit && vite build --mode ${CLOUDFLARE_ENV:-staging}",
    "deploy": "wrangler deploy --keep-vars --env=${CLOUDFLARE_ENV:-staging}"
  },
